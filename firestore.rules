rules_version = '2';

// Treadom Firestore güvenlik kuralları.
service cloud.firestore {
  match /databases/{database}/documents {

    // Kullanıcı dökümanları: users/{uid}
    match /users/{userId} {
      // Giriş yapmış herkes kullanıcıları okuyabilir (sıralama ekranı için).
      allow read: if request.auth != null;

      // Kullanıcı yalnızca KENDİ dökümanını oluşturabilir/güncelleyebilir.
      allow create, update: if request.auth != null
                            && request.auth.uid == userId;

      // Silmeye izin yok.
      allow delete: if false;

      // Yürüme geçmişi: users/{uid}/runs/{runId}
      // Yalnızca dökümanın sahibi kendi turlarını okuyabilir/yazabilir.
      match /runs/{runId} {
        allow read, create: if request.auth != null
                            && request.auth.uid == userId;
        allow update, delete: if false;
      }
    }

    // Fethedilen alanlar: territories/{id}
    //
    // Fetih hesabı `claimTerritory` Cloud Function'ına taşındığından (admin
    // yetkisiyle yazar), istemci alanları yalnızca OKUYABİLİR. Hiçbir istemci
    // doğrudan yazamaz; tüm oluşturma/güncelleme/silme sunucudan gelir.
    match /territories/{territoryId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Sohbetler: chats/{id} ve mesajları.
    // Yalnızca katılımcılar okuyabilir/yazabilir. Sohbet "ended" durumundaysa
    // yeni mesaj yazılamaz (karşıya bir daha mesaj atılamaz).
    match /chats/{chatId} {
      // Döküman henüz yoksa (resource == null) okumaya izin ver ki 1:1 sohbet
      // ilk açılışta "var mı?" kontrolü yapılabilsin; varsa yalnızca katılımcı.
      allow read: if request.auth != null
                  && (resource == null
                      || request.auth.uid in resource.data.participants);
      allow create: if request.auth != null
                    && request.auth.uid in request.resource.data.participants;
      allow update: if request.auth != null
                    && request.auth.uid in resource.data.participants;
      allow delete: if false;

      match /messages/{messageId} {
        function chat() {
          return get(/databases/$(database)/documents/chats/$(chatId)).data;
        }
        allow read: if request.auth != null
                    && request.auth.uid in chat().participants;
        allow create: if request.auth != null
                      && request.auth.uid in chat().participants
                      && chat().status == 'active'
                      && request.resource.data.senderId == request.auth.uid;
        // Katılımcılar yalnızca teslim/okundu durumunu güncelleyebilir
        // (içerik/gönderen değişemez) — "iletildi"/"görüldü" için.
        allow update: if request.auth != null
                      && request.auth.uid in chat().participants
                      && request.resource.data.text == resource.data.text
                      && request.resource.data.senderId == resource.data.senderId;
        allow delete: if false;
      }
    }
  }
}
